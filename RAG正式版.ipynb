import os
import sys
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.document_loaders import PyPDFLoader
from langchain_community.vectorstores import Chroma
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.runnables import RunnablePassthrough, RunnableLambda
from langchain_core.output_parsers import StrOutputParser

# 導入新版 Hugging Face 專用套件
from langchain_huggingface import HuggingFaceEmbeddings, HuggingFaceEndpoint, ChatHuggingFace

# =====================================================================
# 1. 系統環境配置與 Hugging Face Token 設定
# =====================================================================
# 💡 安全改善：從系統環境變數中讀取 Token，避免硬編碼洩漏
HF_TOKEN = os.environ.get("HUGGINGFACEHUB_API_TOKEN")

# =====================================================================
# 2. RAG 核心功能建立
# =====================================================================
def load_and_clean_insurance_policies(pdf_paths):
    all_chunks = []
    text_splitter = RecursiveCharacterTextSplitter(
        chunk_size=500,         
        chunk_overlap=100,      
        separators=["\n第", "\n一、", "\n\n", "\n", " "] 
    )
    
    # 用來記錄真正有成功讀取到的檔案數量
    loaded_files_count = 0
    
    for path in pdf_paths:
        if not os.path.exists(path):
            print(f"⚠️ 找不到檔案: {path}，跳過此保單。")
            continue
            
        print(f"⏳ 正在解析保單: {path}...")
        loader = PyPDFLoader(path)
        docs = loader.load()
        
        for doc in docs:
            doc.metadata["source_file"] = os.path.basename(path)
            
        chunks = text_splitter.split_documents(docs)
        all_chunks.extend(chunks)
        loaded_files_count += 1
        
    print(f"🟢 成功解析 {loaded_files_count} 個檔案，總共切分出 {len(all_chunks)} 個條款文本塊。")
    return all_chunks

def format_docs(docs):
    return "\n\n".join(f"[來源檔案: {doc.metadata.get('source_file', '未知')}]\n{doc.page_content}" for doc in docs)

# ✨ 自訂自適應解析函數：防範雲端 API 回傳 dict 導致的噴錯
def extract_text_from_response(response):
    if hasattr(response, 'content'):
        return response.content
    elif isinstance(response, dict):
        if 'generated_text' in response:
            return response['generated_text']
        elif 'content' in response:
            return response['content']
        return str(response)
    return str(response)

def init_insurance_rag(pdf_list):
    chunks = load_and_clean_insurance_policies(pdf_list)
    if not chunks:
        print("❌ 錯誤：沒有讀取到任何可用的文字塊，請確認保單 PDF 檔案是否存在。")
        return None
    
    print("⏳ 正在載入 Hugging Face 高精度中文 Embedding 模型 (BGE-M3)...")
    embeddings = HuggingFaceEmbeddings(
        model_name="BAAI/bge-m3",
        model_kwargs={'device': 'cuda'}
    )
    
    vector_store = Chroma.from_documents(chunks, embeddings)
    retriever = vector_store.as_retriever(search_kwargs={"k": 3})
    
    system_prompt = (
        "你是一位專業的保險 AI 旅平險專員。請嚴格根據使用者提供或檢索到的【保單條約內文】回答使用者的理賠疑問，如果遇到數字，可以適度轉成中文數字去做對比。\n"
        "應對原則：\n"
        "1. 如果內文沒有記載或無法確定，請直接說「抱歉，根據目前的條款未能找到相關理賠規定」，絕對不可以自己編造答案。\n"
        "2. 回答時必須在句尾明確註明出自哪一份條款檔案（例如：出處：綜合保險）。\n\n"
        "【保單條約內文】:\n{context}"
    )
    
    prompt = ChatPromptTemplate.from_messages([
        ("system", system_prompt),
        ("human", "{input}"),
    ])
    
    print("⏳ 正在連線 Hugging Face 開源對話模型引擎 (Llama-3-Taiwan)...")
    raw_llm = HuggingFaceEndpoint(
        repo_id="meta-llama/Llama-3.1-8B-Instruct", 
        temperature=0.01, 
        max_new_tokens=512,
        stop_sequences=["<|eot_id|>", "\nUser:", "\nHuman:"] 
    )
    
    chat_llm = ChatHuggingFace(llm=raw_llm)
    
    rag_chain = (
        {"context": (lambda x: x["input"]) | retriever | format_docs, "input": (lambda x: x["input"])}
        | prompt
        | chat_llm
        | RunnableLambda(extract_text_from_response) 
        | StrOutputParser()
    )
    return rag_chain

# =====================================================================
# 3. 系統主程式運行與測試
# =====================================================================
if __name__ == "__main__":
    # 請確保這些 PDF 檔案確實存在於你執行的目錄下
    my_policies = [
        "overseas_travel.pdf",
        "個人海外旅行不便保險旅程更改費用傳染病及檢疫給付附加條款.PDF",
        "個人海外旅行不便保險旅程取消費用傳染病及檢疫給付附加條款.PDF",
        "旅行平安保險單示範條款1090708.pdf",
        "海外突發疾病醫療健康保險附約示範條款.pdf",
        "01.臺灣產物旅遊綜合保險_保單條款.pdf",
        "保額限制.pdf",
    ]
    
    # 💡 檢查環境變數
    if not HF_TOKEN:
        print("⚠️ 錯誤：偵測不到系統環境變數 HUGGINGFACEHUB_API_TOKEN！")
        print("請先在終端機中設定環境變數，或使用 .env 檔案引入 Token。")
    else:
        print("🤖 正在初始化開源 AI 旅平險知識庫系統...")
        ai_agent = init_insurance_rag(my_policies)
        
        if ai_agent:
            test_questions = [
                "請問飛機延誤要滿幾個小時才能申請理賠？",
                "如果我的班機因為不可抗力延遲抵達台灣，我的保險會自動延長嗎？最長延長多久？"
            ]
            
            print("\n====== 🤖 開源 AI 專員上線，開始測試問答 ======")
            for q in test_questions:
                print(f"\n🙋 使用者提問: {q}")
                answer = ai_agent.invoke({"input": q})
                print(f"🤖 專員回答:\n{answer}")
                print("-" * 60)
            
            print("\n✨ 進入自主詢問模式 (輸入 'exit' 或 'quit' 結束)")
            while True:
                user_input = input("\n🙋 請輸入您的問題: ")
                if user_input.lower() in ['exit', 'quit', '結束', '退出']:
                    print("🤖 謝謝使用，再見！")
                    break
                
                if not user_input.strip():
                    continue
                
                answer = ai_agent.invoke({"input": user_input})
                print(f"🤖 專員回答:\n{answer}")
                print("-" * 60)
