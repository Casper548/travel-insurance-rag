   "source": [
    "import os\n",
    "import sys\n",
    "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
    "from langchain_community.document_loaders import PyPDFLoader\n",
    "from langchain_community.vectorstores import Chroma\n",
    "from langchain_core.prompts import ChatPromptTemplate\n",
    "from langchain_core.runnables import RunnablePassthrough, RunnableLambda\n",
    "from langchain_core.output_parsers import StrOutputParser\n",
    "\n",
    "# 導入新版 Hugging Face 專用套件\n",
    "from langchain_huggingface import HuggingFaceEmbeddings, HuggingFaceEndpoint, ChatHuggingFace\n",
    "\n",
    "# =====================================================================\n",
    "# 1. 系統環境配置與 Hugging Face Token 設定\n",
    "# =====================================================================\n",
    "# 💡 安全改善：從系統環境變數中讀取 Token，避免硬編碼洩漏\n",
    "HF_TOKEN = os.environ.get(\"HUGGINGFACEHUB_API_TOKEN\")\n",
    "\n",
    "# =====================================================================\n",
    "# 2. RAG 核心功能建立\n",
    "# =====================================================================\n",
    "def load_and_clean_insurance_policies(pdf_paths):\n",
    "    all_chunks = []\n",
    "    text_splitter = RecursiveCharacterTextSplitter(\n",
    "        chunk_size=500,         \n",
    "        chunk_overlap=100,      \n",
    "        separators=[\"\\n第\", \"\\n一、\", \"\\n\\n\", \"\\n\", \" \"] \n",
    "    )\n",
    "    \n",
    "    # 用來記錄真正有成功讀取到的檔案數量\n",
    "    loaded_files_count = 0\n",
    "    \n",
    "    for path in pdf_paths:\n",
    "        if not os.path.exists(path):\n",
    "            print(f\"⚠️ 找不到檔案: {path}，跳過此保單。\")\n",
    "            continue\n",
    "            \n",
    "        print(f\"⏳ 正在解析保單: {path}...\")\n",
    "        loader = PyPDFLoader(path)\n",
    "        docs = loader.load()\n",
    "        \n",
    "        for doc in docs:\n",
    "            doc.metadata[\"source_file\"] = os.path.basename(path)\n",
    "            \n",
    "        chunks = text_splitter.split_documents(docs)\n",
    "        all_chunks.extend(chunks)\n",
    "        loaded_files_count += 1\n",
    "        \n",
    "    print(f\"🟢 成功解析 {loaded_files_count} 個檔案，總共切分出 {len(all_chunks)} 個條款文本塊。\")\n",
    "    return all_chunks\n",
    "\n",
    "def format_docs(docs):\n",
    "    return \"\\n\\n\".join(f\"[來源檔案: {doc.metadata.get('source_file', '未知')}]\\n{doc.page_content}\" for doc in docs)\n",
    "\n",
    "# ✨ 自訂自適應解析函數：防範雲端 API 回傳 dict 導致的噴錯\n",
    "def extract_text_from_response(response):\n",
    "    if hasattr(response, 'content'):\n",
    "        return response.content\n",
    "    elif isinstance(response, dict):\n",
    "        if 'generated_text' in response:\n",
    "            return response['generated_text']\n",
    "        elif 'content' in response:\n",
    "            return response['content']\n",
    "        return str(response)\n",
    "    return str(response)\n",
    "\n",
    "def init_insurance_rag(pdf_list):\n",
    "    chunks = load_and_clean_insurance_policies(pdf_list)\n",
    "    if not chunks:\n",
    "        print(\"❌ 錯誤：沒有讀取到任何可用的文字塊，請確認保單 PDF 檔案是否存在。\")\n",
    "        return None\n",
    "    \n",
    "    print(\"⏳ 正在載入 Hugging Face 高精度中文 Embedding 模型 (BGE-M3)...\")\n",
    "    embeddings = HuggingFaceEmbeddings(\n",
    "        model_name=\"BAAI/bge-m3\",\n",
    "        model_kwargs={'device': 'cuda'}\n",
    "    )\n",
    "    \n",
    "    vector_store = Chroma.from_documents(chunks, embeddings)\n",
    "    retriever = vector_store.as_retriever(search_kwargs={\"k\": 3})\n",
    "    \n",
    "    system_prompt = (\n",
    "        \"你是一位專業的保險 AI 旅平險專員。請嚴格根據使用者提供或檢索到的【保單條約內文】回答使用者的理賠疑問，如果遇到數字，可以適度轉成中文數字去做對比。\\n\"\n",
    "        \"應對原則：\\n\"\n",
    "        \"1. 如果內文沒有記載或無法確定，請直接說「抱歉，根據目前的條款未能找到相關理賠規定」，絕對不可以自己編造答案。\\n\"\n",
    "        \"2. 回答時必須在句尾明確註明出自哪一份條款檔案（例如：出處：綜合保險）。\\n\\n\"\n",
    "        \"【保單條約內文】:\\n{context}\"\n",
    "    )\n",
    "    \n",
    "    prompt = ChatPromptTemplate.from_messages([\n",
    "        (\"system\", system_prompt),\n",
    "        (\"human\", \"{input}\"),\n",
    "    ])\n",
    "    \n",
    "    print(\"⏳ 正在連線 Hugging Face 開源對話模型引擎 (Llama-3-Taiwan)...\")\n",
    "    raw_llm = HuggingFaceEndpoint(\n",
    "        repo_id=\"meta-llama/Llama-3.1-8B-Instruct\", \n",
    "        temperature=0.01, \n",
    "        max_new_tokens=512,\n",
    "        stop_sequences=[\"<|eot_id|>\", \"\\nUser:\", \"\\nHuman:\"] \n",
    "    )\n",
    "    \n",
    "    chat_llm = ChatHuggingFace(llm=raw_llm)\n",
    "    \n",
    "    rag_chain = (\n",
    "        {\"context\": (lambda x: x[\"input\"]) | retriever | format_docs, \"input\": (lambda x: x[\"input\"])}\n",
    "        | prompt\n",
    "        | chat_llm\n",
    "        | RunnableLambda(extract_text_from_response) \n",
    "        | StrOutputParser()\n",
    "    )\n",
    "    return rag_chain\n",
    "\n",
    "# =====================================================================\n",
    "# 3. 系統主程式運行與測試\n",
    "# =====================================================================\n",
    "if __name__ == \"__main__\":\n",
    "    # 請確保這些 PDF 檔案確實存在於你執行的目錄下\n",
    "    my_policies = [\n",
    "        \"overseas_travel.pdf\",\n",
    "        \"個人海外旅行不便保險旅程更改費用傳染病及檢疫給付附加條款.PDF\",\n",
    "        \"個人海外旅行不便保險旅程取消費用傳染病及檢疫給付附加條款.PDF\",\n",
    "        \"旅行平安保險單示範條款1090708.pdf\",\n",
    "        \"海外突發疾病醫療健康保險附約示範條款.pdf\",\n",
    "        \"01.臺灣產物旅遊綜合保險_保單條款.pdf\",\n",
             \"保額限制.pdf",\n",
    "    ]\n",
    "    \n",
    "    # 💡 檢查環境變數\n",
    "    if not HF_TOKEN:\n",
    "        print(\"⚠️ 錯誤：偵測不到系統環境變數 HUGGINGFACEHUB_API_TOKEN！\")\n",
    "        print(\"請先在終端機中設定環境變數，或使用 .env 檔案引入 Token。\")\n",
    "    else:\n",
    "        print(\"🤖 正在初始化開源 AI 旅平險知識庫系統...\")\n",
    "        ai_agent = init_insurance_rag(my_policies)\n",
    "        \n",
    "        if ai_agent:\n",
    "            test_questions = [\n",
    "                \"請問飛機延誤要滿幾個小時才能申請理賠？\",\n",
    "                \"如果我的班機因為不可抗力延遲抵達台灣，我的保險會自動延長嗎？最長延長多久？\"\n",
    "            ]\n",
    "            \n",
    "            print(\"\\n====== 🤖 開源 AI 專員上線，開始測試問答 ======\")\n",
    "            for q in test_questions:\n",
    "                print(f\"\\n🙋 使用者提問: {q}\")\n",
    "                answer = ai_agent.invoke({\"input\": q})\n",
    "                print(f\"🤖 專員回答:\\n{answer}\")\n",
    "                print(\"-\" * 60)\n",
    "            \n",
    "            print(\"\\n✨ 進入自主詢問模式 (輸入 'exit' 或 'quit' 結束)\")\n",
    "            while True:\n",
    "                user_input = input(\"\\n🙋 請輸入您的問題: \")\n",
    "                if user_input.lower() in ['exit', 'quit', '結束', '退出']:\n",
    "                    print(\"🤖 謝謝使用，再見！\")\n",
    "                    break\n",
    "                \n",
    "                if not user_input.strip():\n",
    "                    continue\n",
    "                \n",
    "                answer = ai_agent.invoke({\"input\": user_input})\n",
    "                print(f\"🤖 專員回答:\\n{answer}\")\n",
    "                print(\"-\" * 60)"
   ]
  }
 ],
